{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Third Kind Contact",
  "version": "0.1.0",
  "identifier": "com.thirdkind.contact.clean",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Third Kind Contact",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 620,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "resizable": true,
        "center": true,
        "skipTaskbar": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/scene_assets/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
