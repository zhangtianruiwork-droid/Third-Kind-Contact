{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "英灵殿",
  "version": "0.1.0",
  "identifier": "com.yingling.pet",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "英灵殿",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 620,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "resizable": true,
        "center": true,
        "skipTaskbar": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/scene_assets/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
